# --- Supabase (public, safe to expose to the browser) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-or-publishable-key

# --- NVIDIA (server-only secret — never expose to the browser) ---
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: override the model used for signal generation
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
