# --- Supabase (public, safe to expose to the browser) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-or-publishable-key

# --- Supabase (server-only secret — used for payment confirmation) ---
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- NVIDIA (server-only secret — never expose to the browser) ---
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: override the model used for signal generation
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# --- Crypto payments (USDT on TRON / TRC20) ---
# Your receiving wallet address (TRC20). Payments are watched on-chain.
PAYMENT_TRON_ADDRESS=Txxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: TronGrid API key (raises rate limits). https://www.trongrid.io
TRONGRID_API_KEY=
# Recommended: secret to protect the /api/payments/check and
# /api/trends/generate cron endpoints.
CRON_SECRET=some-long-random-string

# --- Mentoring (optional) ---
# Where "Join session" buttons link to (Telegram, Zoom, Discord, etc.). If
# unset, members are shown a contact-us link instead.
NEXT_PUBLIC_MENTORING_LINK=
